{% if context.trajectory and context.trajectory.rounds %}
{% set agent_best = {} %}
{% for rnd in context.trajectory.rounds %}
{% for agent in rnd.agents %}
{% set key = agent.agent_id or agent.name %}
{% if key %}
{% set prev = agent_best.get(key) %}
{% if (prev is none) or (agent.score | abs) > (prev.score | abs) %}
{% set _ = agent_best.update({key: {'name': agent.name, 'agent_id': agent.agent_id, 'score': agent.score, 'stance': agent.stance, 'message': agent.message}}) %}
{% endif %}
{% endif %}
{% endfor %}
{% endfor %}

