{% set verbatim = (art.content[:340] + ('…' if art.content | length > 340 else '')) %}
{% set verbatim_source = 'article ' ~ (art.platform or 'simulé') ~ ', round ' ~ (art.round | default('—')) %}
{% endif %}
{% endfor %}
{% endif %}
{# 3. Message le plus long de l'agent dans la trajectoire. #}
{% set agent_key = agent.agent_id or agent.name %}
{% if not verbatim and agent_messages.get(agent_key) %}
{% set best = agent_messages[agent_key] %}
{% set verbatim = (best.message[:340] + ('…' if best.message | length > 340 else '')) %}
{% set verbatim_source = 'canal interne, round ' ~ best.round %}
{% endif %}
{# 4. Dernier message non vide (legacy). #}
{% if not verbatim and agent.message %}
{% set verbatim = (agent.message[:340] + ('…' if agent.message | length > 340 else '')) %}
{% set verbatim_source = 'round ' ~ agent.round %}
{% endif %}
{# 5. Fallback narratif — pas de chiffre brut isolé. #}
{% if not verbatim %}
