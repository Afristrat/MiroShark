/* pdf_brand.css.j2 — CSS Jinja2 pour le rendu WeasyPrint Bassira.
   Variables injectées depuis le branding row (pdf_branding table) ou defaults Bassira.
*/

/* ── Variables palette Bassira / Causse Warm Intelligence ──────────────────── */
:root {
{% if branding and branding.get('palette_primary') %}
  --wi-orange:   {{ branding.palette_primary }};
{% else %}
  --wi-orange:   #FF8551;
{% endif %}
{% if branding and branding.get('palette_secondary') %}
  --wi-mint:     {{ branding.palette_secondary }};
{% else %}
  --wi-mint:     #006D44;
{% endif %}
{% if branding and branding.get('palette_background') %}
  --wi-cream:    {{ branding.palette_background }};
{% else %}
  --wi-cream:    #FAF7F2;
{% endif %}
{% if branding and branding.get('palette_text') %}
  --wi-charcoal: {{ branding.palette_text }};
{% else %}
  --wi-charcoal: #241915;
{% endif %}
  --wi-terra:    #A13F0F;
  --wi-sand:     #E8DDC9;
  --wi-ink:      #1A0F0A;
}

/* ── @font-face ─────────────────────────────────────────────────────────────── */
{% if branding and branding.get('font_titles') %}
/* Custom title font from branding */
{% else %}
@font-face {
  font-family: 'Outfit';
  src: url('../fonts/Outfit-Regular.woff2') format('woff2');
  font-weight: normal;
  font-style: normal;
}
@font-face {
  font-family: 'Outfit';
  src: url('../fonts/Outfit-Bold.woff2') format('woff2');
  font-weight: bold;
  font-style: normal;
}
{% endif %}
@font-face {
  font-family: 'Manrope';
  src: url('../fonts/Manrope-Regular.woff2') format('woff2');
  font-weight: normal;
  font-style: normal;
}
@font-face {
  font-family: 'Manrope';
  src: url('../fonts/Manrope-Bold.woff2') format('woff2');
  font-weight: bold;
  font-style: normal;
}
@font-face {
  font-family: 'Tajawal';
  src: url('../fonts/Tajawal-Regular.woff2') format('woff2');
  font-weight: normal;
  font-style: normal;
}
@font-face {
  font-family: 'Tajawal';
  src: url('../fonts/Tajawal-Bold.woff2') format('woff2');
  font-weight: bold;
  font-style: normal;
}

/* ── Page rules ─────────────────────────────────────────────────────────────── */
@page {
  size: A4;
  margin: 25mm 18mm 22mm 18mm;

  @top-right {
    content: counter(page) " / " counter(pages);
    font-family: Manrope, 'DejaVu Sans', sans-serif;
    font-size: 9pt;
    color: var(--wi-charcoal);
    opacity: 0.6;
  }

  @bottom-left {
    content: "{{ context.report_id if context is defined else '' }}";
    font-family: Manrope, 'DejaVu Sans', sans-serif;
    font-size: 7pt;
    color: var(--wi-charcoal);
    opacity: 0.5;
  }

  @bottom-center {
    content: "Bassira © {{ generated_at[:4] if generated_at is defined else '2026' }}";
    font-family: Manrope, 'DejaVu Sans', sans-serif;
    font-size: 7pt;
    color: var(--wi-charcoal);
    opacity: 0.5;
  }

  @bottom-right {
    content: "{{ generated_at[:10] if generated_at is defined else '' }}";
    font-family: Manrope, 'DejaVu Sans', sans-serif;
    font-size: 7pt;
    color: var(--wi-charcoal);
    opacity: 0.5;
  }
}

/* Cover page : no header/footer */
@page :first {
  margin-top: 40mm;

  @top-right { content: none; }
  @bottom-left { content: none; }
  @bottom-center { content: none; }
  @bottom-right { content: none; }
}

/* ── Base ──────────────────────────────────────────────────────────────────── */
html, body {
  font-family: {% if branding and branding.get('font_body') %}{{ branding.font_body }}{% else %}Manrope, 'DejaVu Sans', sans-serif{% endif %};
  font-size: 11pt;
  line-height: 1.6;
  color: var(--wi-charcoal);
  background-color: var(--wi-cream);
}

/* ── Headings ────────────────────────────────────────────────────────────────── */
h1 {
  font-family: {% if branding and branding.get('font_titles') %}{{ branding.font_titles }}{% else %}Outfit, 'DejaVu Sans', sans-serif{% endif %};
  font-size: 24pt;
  color: var(--wi-orange);
  margin-top: 0;
  margin-bottom: 12pt;
  line-height: 1.2;
}

h2 {
  font-family: {% if branding and branding.get('font_titles') %}{{ branding.font_titles }}{% else %}Outfit, 'DejaVu Sans', sans-serif{% endif %};
  font-size: 18pt;
  color: var(--wi-charcoal);
  margin-top: 24pt;
  margin-bottom: 8pt;
  border-bottom: 2pt solid var(--wi-sand);
  padding-bottom: 4pt;
}

h3 {
  font-family: {% if branding and branding.get('font_titles') %}{{ branding.font_titles }}{% else %}Outfit, 'DejaVu Sans', sans-serif{% endif %};
  font-size: 14pt;
  color: var(--wi-terra);
  margin-top: 16pt;
  margin-bottom: 6pt;
}

h4, h5, h6 {
  font-family: Manrope, 'DejaVu Sans', sans-serif;
  font-size: 11pt;
  color: var(--wi-charcoal);
  margin-top: 12pt;
  margin-bottom: 4pt;
}

/* ── Paragraphs ─────────────────────────────────────────────────────────────── */
p {
  font-family: Manrope, 'DejaVu Sans', sans-serif;
  font-size: 11pt;
  margin-bottom: 8pt;
  orphans: 3;
  widows: 3;
}

/* ── Tables ─────────────────────────────────────────────────────────────────── */
table {
  width: 100%;
  border-collapse: collapse;
  margin: 12pt 0;
  font-size: 10pt;
}

th {
  background-color: var(--wi-charcoal);
  color: var(--wi-cream);
  font-family: Manrope, 'DejaVu Sans', sans-serif;
  font-weight: bold;
  padding: 6pt 8pt;
  text-align: left;
}

td {
  padding: 5pt 8pt;
  border-bottom: 0.5pt solid var(--wi-sand);
  vertical-align: top;
}

tr:nth-child(even) td {
  background-color: var(--wi-sand);
}

/* ── Blockquotes ─────────────────────────────────────────────────────────────── */
blockquote {
  border-left: 4pt solid var(--wi-terra);
  margin: 12pt 0;
  padding: 8pt 12pt;
  font-style: italic;
  color: var(--wi-terra);
  background-color: #FFF5EE;
}

/* ── KPI cards (refonte production-ready B1) ────────────────────────────────── */
.kpi-card {
  display: block;
  margin: 12pt 0;
  padding: 14pt 18pt;
  border-left: 4pt solid var(--wi-orange);
  background-color: #FFF5EE;
  border-radius: 2pt;
  page-break-inside: avoid;
}

.kpi-card-label {
  font-size: 9pt;
  font-weight: bold;
  color: var(--wi-terra);
  text-transform: uppercase;
  letter-spacing: 0.5pt;
  margin-bottom: 4pt;
}

.kpi-card-value {
  font-size: 28pt;
  font-weight: bold;
  color: var(--wi-orange);
  line-height: 1.1;
  margin-bottom: 4pt;
}

.kpi-card-unit {
  font-size: 14pt;
  font-weight: normal;
  color: var(--wi-charcoal);
  opacity: 0.7;
}

.kpi-card-footer {
  font-size: 9pt;
  font-style: italic;
  color: var(--wi-charcoal);
  opacity: 0.6;
}

.kpi-card-primary { border-left-color: var(--wi-orange); }
.kpi-card-mint    { border-left-color: var(--wi-mint); }
.kpi-card-terra   { border-left-color: var(--wi-terra); }

/* Old single-line KPI badges (compat) */
.kpi-orange { background-color: var(--wi-orange); color: white; padding: 4pt 8pt; border-radius: 2pt; }
.kpi-mint   { background-color: var(--wi-mint);   color: white; padding: 4pt 8pt; border-radius: 2pt; }
.kpi-terra  { background-color: var(--wi-terra);  color: white; padding: 4pt 8pt; border-radius: 2pt; }

/* ── Callouts (admonitions GFM converties, B4) ──────────────────────────────── */
.callout {
  margin: 12pt 0;
  padding: 10pt 14pt 10pt 18pt;
  border-left: 4pt solid var(--wi-sand);
  background-color: #FFFCF7;
  border-radius: 2pt;
  page-break-inside: avoid;
}

.callout-label {
  font-size: 9pt;
  font-weight: bold;
  text-transform: uppercase;
  letter-spacing: 0.4pt;
  margin-bottom: 4pt;
  color: var(--wi-charcoal);
  opacity: 0.85;
}

.callout p {
  margin: 4pt 0;
  font-style: normal;
  color: var(--wi-charcoal);
}

.callout-info    { border-left-color: var(--wi-mint);   background-color: #F0F7F3; }
.callout-info    .callout-label { color: var(--wi-mint); }
.callout-warning { border-left-color: var(--wi-orange); background-color: #FFF5EE; }
.callout-warning .callout-label { color: var(--wi-terra); }
.callout-critical{ border-left-color: #B0260F;          background-color: #FBEEEA; }
.callout-critical .callout-label { color: #B0260F; }

/* ── Encart « Méthode et limites » (US-202, transparence AI Act art. 50) ────── */
.method-limits {
  margin: 14pt 0;
  padding: 10pt 14pt 10pt 18pt;
  border-left: 4pt solid var(--wi-mint);
  background-color: #F0F7F3;
  border-radius: 2pt;
  page-break-inside: avoid;
  font-size: 9pt;
}

.method-limits p {
  margin: 4pt 0;
  color: var(--wi-charcoal);
}

.method-limits-marking {
  display: block;
  margin-top: 6pt;
  font-size: 8pt;
  letter-spacing: 0.3pt;
  text-transform: uppercase;
  color: var(--wi-mint);
}

/* En RTL (dir posé sur le div par le template), la bordure passe à droite. */
.method-limits[dir="rtl"] {
  border-left: none;
  border-right: 4pt solid var(--wi-mint);
  padding: 10pt 18pt 10pt 14pt;
}

/* ── Pull quotes (citations agents, B11) ────────────────────────────────────── */
.pull-quote {
  margin: 12pt 0;
  padding: 10pt 14pt 10pt 18pt;
  border-left: 4pt solid var(--wi-terra);
  background-color: #FFF5EE;
  font-style: italic;
  color: var(--wi-charcoal);
  page-break-inside: avoid;
}
.pull-quote p {
  margin: 0 0 4pt 0;
  font-style: italic;
}
.pull-quote footer {
  font-size: 9pt;
  font-style: normal;
  color: var(--wi-terra);
  opacity: 0.85;
}

/* ── Sections groupées pour éviter les sauts de page parasites (B8, B14) ────── */
.pivots-section, .agent-table-section {
  page-break-inside: auto;
}
.pivots-section h4, .agent-table-section h4 {
  page-break-after: avoid;
}

/* ── Lists ───────────────────────────────────────────────────────────────────── */
ul, ol {
  margin: 6pt 0 10pt 18pt;
  padding: 0;
}

li {
  margin-bottom: 3pt;
  font-size: 11pt;
}

/* ── Images / Charts ─────────────────────────────────────────────────────────── */
img {
  max-width: 100%;
  height: auto;
  display: block;
  margin: 12pt auto;
}

/* ── Code / monospace ────────────────────────────────────────────────────────── */
code, pre {
  font-family: {% if branding and branding.get('font_mono') %}{{ branding.font_mono }}{% else %}'Courier New', monospace{% endif %};
  font-size: 9pt;
  background-color: var(--wi-sand);
  padding: 2pt 4pt;
  border-radius: 2pt;
}

pre {
  padding: 8pt 12pt;
  overflow: hidden;
  white-space: pre-wrap;
}

/* ── Horizontal rule ────────────────────────────────────────────────────────── */
hr {
  border: none;
  border-top: 1pt solid var(--wi-sand);
  margin: 16pt 0;
}

/* ── Page break helpers ─────────────────────────────────────────────────────── */
h1, h2 {
  page-break-after: avoid;
}

table, figure {
  page-break-inside: avoid;
}

/* ── RTL support ─────────────────────────────────────────────────────────────── */
{% if lang == 'ar' %}
html[dir="rtl"], [dir="rtl"] {
  font-family: Tajawal, 'DejaVu Sans', sans-serif;
  direction: rtl;
  text-align: right;
}

[dir="rtl"] th {
  text-align: right;
}

[dir="rtl"] blockquote {
  border-left: none;
  border-right: 4pt solid var(--wi-terra);
  padding: 8pt 12pt 8pt 8pt;
}

[dir="rtl"] ul, [dir="rtl"] ol {
  margin: 6pt 18pt 10pt 0;
}
{% endif %}

/* ── Disclaimer ──────────────────────────────────────────────────────────────── */
{% if branding and branding.get('disclaimer_text') %}
.disclaimer {
  font-size: 7pt;
  color: var(--wi-charcoal);
  opacity: 0.6;
  margin-top: 16pt;
  padding-top: 8pt;
  border-top: 0.5pt solid var(--wi-sand);
}
{% endif %}

/* ── One-pager layout (US-131) ───────────────────────────────────────────────── */
/* Conteneur principal one-pager — tient sur une seule page A4 */
.one-pager-layout {
  display: block;
  width: 100%;
  max-height: 240mm;
  overflow: hidden;
}

/* En-tête one-pager */
.one-pager-header h1 {
  font-size: 16pt;
  margin-bottom: 4pt;
}

.one-pager-header p {
  font-size: 9pt;
  margin-bottom: 4pt;
}

/* Grille KPI 2 colonnes (CSS Grid) — WeasyPrint >= 60 supporte grid */
.kpi-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6pt;
  margin: 8pt 0;
}

/* Cartes KPI dans le one-pager */
.kpi-grid .kpi-card {
  display: block;
  padding: 6pt 8pt;
  border-radius: 4pt;
  background-color: var(--wi-sand);
  text-align: center;
  font-size: 9pt;
}

.kpi-grid .kpi-card h1 {
  font-size: 14pt;
  margin: 2pt 0;
  color: var(--wi-charcoal);
}

.kpi-grid .kpi-primary {
  background-color: var(--wi-orange);
  color: white;
}

.kpi-grid .kpi-primary h1 {
  color: white;
}

.kpi-grid .kpi-secondary {
  background-color: var(--wi-mint);
  color: white;
}

.kpi-grid .kpi-secondary h1 {
  color: white;
}

.kpi-grid .kpi-success {
  background-color: var(--wi-mint);
  color: white;
}

.kpi-grid .kpi-success h1 {
  color: white;
}

.kpi-grid .kpi-warning {
  background-color: var(--wi-terra);
  color: white;
}

.kpi-grid .kpi-warning h1 {
  color: white;
}

/* Sections verdict et recommandations one-pager */
.one-pager-verdict {
  margin: 6pt 0;
}

.one-pager-verdict h2 {
  font-size: 12pt;
  margin-top: 4pt;
  margin-bottom: 4pt;
}

.one-pager-reco {
  margin: 6pt 0;
}

.one-pager-reco h2 {
  font-size: 12pt;
  margin-top: 4pt;
  margin-bottom: 4pt;
}

.one-pager-reco p {
  font-size: 9pt;
  margin-bottom: 3pt;
}

/* Pied de page one-pager */
.one-pager-footer {
  margin-top: 6pt;
  font-size: 7pt;
  color: var(--wi-charcoal);
  opacity: 0.6;
}

/* Réduire taille texte pour one-pager */
.one-pager-layout p {
  font-size: 9pt;
  margin-bottom: 3pt;
}

.one-pager-layout h3 {
  font-size: 11pt;
  margin-top: 6pt;
}

.one-pager-layout hr {
  margin: 6pt 0;
}
